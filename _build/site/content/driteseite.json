,"implicit":true,"key":"Ak7fqOpdCY"},{"type":"code","lang":"python","value":"import pandas as pd\n\n# Datensatz laden\ndf = pd.read_csv(\"projektdaten.csv\", parse_dates=[\"Datum\"])\n\n# Fehlende Werte in der Spalte 'Umsatz' durch den Median ersetzen\nmedian_umsatz = df[\"Umsatz\"].median()\ndf[\"Umsatz\"].fillna(median_umsatz, inplace=True)\n\n# Nur erfolgreiche Transaktionen filtern\ndf_clean = df[df[\"Status\"] == \"Erfolgreich\"]\n","position":{"start":{"line":33,"column":1},"end":{"line":45,"column":1}},"key":"SpdnSzXHCL"}],"key":"qY0G3ydird"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"4.2 Datenaggregation","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"qKSCaQioJd"}],"identifier":"id-4-2-datenaggregation","label":"4.2 Datenaggregation","html_id":"id-4-2-datenaggregation","implicit":true,"key":"jTRuUYpg8i"}],"key":"hVqpD7g7AE"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-06-18T08:41:17.404696500Z","start_time":"2026-06-18T08:41:17.349400300Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport pandas as pd\n\n# 1. Wir erstellen uns selbst künstliche Testdaten (damit der Code läuft)\ndata = {\n    \"Datum\": [\"2026-01-15\", \"2026-01-16\", \"2026-02-01\", \"2026-02-15\", \"2026-03-01\"],\n    \"Kategorie\": [\"Elektronik\", \"Bürobedarf\", \"Elektronik\", \"Elektronik\", \"Bürobedarf\"],\n    \"Umsatz\": [549.99, 24.50, 89.00, 120.00, 45.00],\n    \"Status\": [\"Erfolgreich\", \"Storniert\", \"Erfolgreich\", \"Erfolgreich\", \"Erfolgreich\"]\n}\n\n# Das ist das ursprüngliche DataFrame (df)\ndf = pd.DataFrame(data)\n\n# 2. Schritt 4.1: Daten filtern (Nur 'Erfolgreich' behalten)\n# Hier wird 'df_clean' definiert!\ndf_clean = df[df[\"Status\"] == \"Erfolgreich\"].copy()\n\n# Sicherstellen, dass das Datum ein echtes Datetime-Objekt ist\ndf_clean[\"Datum\"] = pd.to_datetime(df_clean[\"Datum\"])\n\n\n# 3. Schritt 4.2: Datenaggregation (Umsatz pro Kategorie und Monat)\nmonats_report = (\n    df_clean.groupby([\"Kategorie\", df_clean[\"Datum\"].dt.to_period(\"M\")])\n    .agg(Gesamtumsatz=(\"Umsatz\", \"sum\"), Anzahl_Verkaeufe=(\"Umsatz\", \"count\"))\n    .reset_index()\n)\n\n# 4. Ergebnis im Notebook anzeigen\nprint(\"--- Aggregierter Monatsbericht ---\")\nprint(monats_report)","key":"yRbh31qc7V"},{"type":"outputs","id":"fApU_61Kup80GPTd3f2R5","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"--- Aggregierter Monatsbericht ---\n    Kategorie    Datum  Gesamtumsatz  Anzahl_Verkaeufe\n0  Bürobedarf  2026-03         45.00                 1\n1  Elektronik  2026-01        549.99                 1\n2  Elektronik  2026-02        209.00                 2\n"},"children":[],"key":"nDB03yx4mJ"}],"key":"s3drlh7pS6"}],"key":"zFmJ2Df6Os"},{"type":"block","kind":"notebook-content","children":[{"type":"list","ordered":true,"start":5,"spread":false,"position":{"start":{"line":1,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":1,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Leitfaden für die Erstellung von Jupyter Books\nWenn dieses Notebook (.ipynb) in ein digitales Buch oder eine Website kompiliert werden soll, müssen bestimmte Formatierungsregeln für Jupyter Book eingehalten werden.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"mT9pGoTr9W"}],"key":"yNh948zsJ7"}],"key":"fu7nZzH6ty"}],"key":"lVzaJyl1j3"}],"key":"iXfC33cXel"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Nutze für wichtige Randbemerkungen immer die spezifische Admonition-Syntax von MyST-Markd